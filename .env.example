# Banco de dados MySQL (Railway, PlanetScale, etc)
DATABASE_URL=mysql://user:password@host:3306/larf_projetos

# JWT secret — gere com: openssl rand -base64 32
JWT_SECRET=troque_por_uma_string_aleatoria_de_32_chars_ou_mais

# Resend (opcional — para e-mails de recuperação de senha)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Porta do servidor (Railway define automaticamente)
PORT=3000
